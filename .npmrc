# .npmrc

# Solo instala paquetes del registry oficial de npm
registry=https://registry.npmjs.org/

# Fuerza que el lockfile esté siempre actualizado (evita instalar versiones distintas)
save-exact=true

# Evita ejecutar scripts arbitrarios de paquetes durante la instalación
ignore-scripts=false

# Verifica la integridad de los paquetes descargados (activo por defecto, lo forzamos)
audit=true

# Fuerza HTTPS siempre
strict-ssl=true

# Evita que se instalen paquetes como root
allow-root=false
